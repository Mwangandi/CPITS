# API Configuration
# API credentials are now server-side only (in file-proxy/.env)
# No VITE_API_KEY or VITE_API_SECRET needed — proxy injects credentials

# Gemini AI (optional)
VITE_GEMINI_API_KEY=your_gemini_key_here

# Debug logging - set to 'true' to enable console debug logs
VITE_DEBUG=false

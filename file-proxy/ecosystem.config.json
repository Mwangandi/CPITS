{
  "apps": [
    {
      "name": "frappe-file-proxy",
      "script": "server.js",
      "cwd": "./",
      "instances": 1,
      "exec_mode": "fork",
      "env": {
        "NODE_ENV": "production"
      },
      "max_memory_restart": "256M",
      "log_date_format": "YYYY-MM-DD HH:mm:ss",
      "error_file": "./logs/error.log",
      "out_file": "./logs/output.log",
      "merge_logs": true,
      "restart_delay": 3000,
      "max_restarts": 10,
      "min_uptime": 5000
    }
  ]
}
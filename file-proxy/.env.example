# Frappe backend URL (no trailing slash)
FRAPPE_BASE_URL=https://cpits.taitataveta.go.ke

# Frappe API credentials (from User API Key settings)
API_KEY=your_api_key_here
API_SECRET=your_api_secret_here

# Token that frontend sends to authenticate with this proxy
ACCESS_TOKEN=generate_a_strong_random_token_here

# Secret for signed URL HMAC signatures (optional, enables signed URLs)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SIGNING_SECRET=

# Server port
PORT=3001

# Cache TTL in seconds (default: 3600 = 1 hour)
CACHE_TTL=3600

# Max cached files (default: 500)
MAX_CACHE_KEYS=500

# Allowed CORS origins (comma-separated, or * for all)
ALLOWED_ORIGINS=https://cpits.taitataveta.go.ke
